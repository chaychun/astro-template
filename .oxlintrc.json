{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "import", "jsx-a11y", "react"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn",
    "pedantic": "off",
    "style": "off",
    "nursery": "off",
    "restriction": "off"
  },
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "settings": {
    "react": {
      "version": "19.0"
    }
  },
  "rules": {
    "no-console": "warn",
    "eqeqeq": "error",
    "react/react-in-jsx-scope": "off"
  },
  "ignorePatterns": ["dist", ".astro", "node_modules", "public", "*.astro"]
}
